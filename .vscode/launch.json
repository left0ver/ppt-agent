{
  // 使用 IntelliSense 了解相关属性。 
  // 悬停以查看现有属性的描述。
  // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [

    {
      "name": "debug FastAPI",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "backend.main:app",
        "--reload",
        "--port",
        "8000",
        "--reload-dir",
        "./backend",
        // "--reload-dir",
        // "./agent"
      ],
      "cwd": "${workspaceFolder}",
      "jinja": true
    },
    {
      "name": "debug Streamlit",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "frontend/app.py"
      ],
      "cwd": "${workspaceFolder}",
      "jinja": true
    }
  ]
}
